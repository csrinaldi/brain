# Personal Access Token for your Git hosting provider (GitLab, GitHub, Bitbucket, etc.)
# Scope required: api (read/write issues, MRs/PRs, packages)
GITLAB_TOKEN=

# SDD harness implementation to use. Default: gentle-ai
# Supported: gentle-ai | (extend via scripts/bootstrap.sh §6)
SDD_HARNESS=gentle-ai

# Memory backend to use. Default: engram
# Supported: engram | (extend via scripts/memory/cli.mjs)
MEMORY_BACKEND=engram

# Comma-separated list of hosts to bypass the corporate proxy (if any)
# Example: NO_PROXY=localhost,127.0.0.1,mygitlab.company.com
NO_PROXY=
