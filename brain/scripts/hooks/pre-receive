#!/usr/bin/env sh
# pre-receive — server-side hard gate for commit-message invariants.
#
# This is the bypass-proof server-side counterpart of brain/scripts/hooks/commit-msg.
# Unlike the client-side commit-msg hook, this hook runs on the git SERVER and CANNOT
# be skipped with --no-verify (which is a client-only flag that only suppresses local
# hooks). It enforces the same conventional-commit format and ticket-reference
# requirements for every commit in a pushed batch.
#
# Requirements: sh, git, grep — no Node.js or external tooling required.
# Installed via: npm run brain:protect-server -- /path/to/repo.git
#
# Per-line stdin format (one line per ref being pushed):
#   <oldrev> <newrev> <refname>
#   - oldrev:  40-hex SHA, or 40 zeros for a newly-created ref
#   - newrev:  40-hex SHA, or 40 zeros for a deleted ref
#   - refname: e.g. refs/heads/main
#
# Checks mirrored from commit-msg:
#   1. Conventional commit format: <type>[(<scope>)][!]: <description>
#   2. Ticket ref (#N) — exempt for Merge, Revert, chore(release), chore(memory).

ZEROS="0000000000000000000000000000000000000000"
failed=0

while IFS=' ' read -r oldrev newrev refname; do
  # Skip branch/tag deletions (newrev is all zeros).
  [ "$newrev" = "$ZEROS" ] && continue

  # Determine the set of new commits to validate. A hard gate must fail CLOSED:
  # if git rev-list errors (corrupt object DB, unknown SHA, OOM), reject the push
  # rather than let an empty list silently accept unvalidated commits.
  if [ "$oldrev" = "$ZEROS" ]; then
    # New ref: list commits reachable from newrev that are not yet in any existing ref.
    commits=$(git rev-list "$newrev" --not --all) || {
      printf '✗ pre-receive: internal error listing commits for %s — rejecting push.\n' "$refname"
      exit 1
    }
  else
    # Existing ref: list commits added on top of the previous tip.
    commits=$(git rev-list "$oldrev..$newrev") || {
      printf '✗ pre-receive: internal error listing commits for %s — rejecting push.\n' "$refname"
      exit 1
    }
  fi

  for sha in $commits; do
    msg=$(git log -1 --format=%B "$sha")
    sha7=$(printf '%s' "$sha" | cut -c1-7)

    # Skip empty messages.
    [ -z "$msg" ] && continue

    # Exemptions: Merge and Revert commits bypass both checks (same as commit-msg).
    case "$msg" in
      Merge\ *|Revert\ *) continue ;;
    esac

    # ── 1. Conventional commit format ────────────────────────────────────────
    if ! printf '%s\n' "$msg" | grep -qE \
      '^(feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert)(\([^)]+\))?(!)?: .+'; then
      printf '\n'
      printf '✗ pre-receive: %s — commit message must follow Conventional Commits.\n' "$sha7"
      printf '  Message: %s\n' "$(printf '%s\n' "$msg" | head -n 1)"
      printf '  Format:  <type>[(<scope>)]: <description>\n'
      printf '  Types:   feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert\n'
      failed=1
      continue
    fi

    # ── 2. Ticket reference ───────────────────────────────────────────────────
    # Machine-generated commits (release cuts and memory syncs) carry no ticket —
    # exempt them from the ref requirement. Format is still enforced above.
    case "$msg" in
      chore\(release\)*|chore\(memory\)*) continue ;;
    esac

    if ! printf '%s\n' "$msg" | grep -qE '#[0-9]+'; then
      printf '\n'
      printf '✗ pre-receive: %s — commit message must reference a ticket (#N).\n' "$sha7"
      printf '  Message: %s\n' "$(printf '%s\n' "$msg" | head -n 1)"
      printf '  Example: feat(auth): add JWT validation (#42)\n'
      failed=1
    fi
  done
done

if [ "$failed" -ne 0 ]; then
  printf '\n'
  printf 'Push rejected by brain'\''s pre-receive hard gate — fix the commit message(s) and re-push.\n'
  exit 1
fi

exit 0
