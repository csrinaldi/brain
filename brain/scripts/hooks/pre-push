#!/usr/bin/env sh
# pre-push — materializa la memoria viva en .memory/ antes del push (ADR-0002).
#
# La capa Viva de memoria (sesión, errores, contexto) viaja en .memory/ commiteado
# y entra a main al mergear el MR. Este hook garantiza que esa materialización
# ocurra ANTES del push, en lugar de depender de que el dev recuerde memory:share.
#
# Comportamiento:
#   - Sin node instalado (CI, clone fresco) → no bloquea (exit 0).
#   - Dispatcha `memory:share` vía brain/scripts/memory/cli.mjs (backend-agnóstico, MEMORY_BACKEND).
#   - Si .memory/ queda con cambios sin commitear (staged, unstaged o untracked)
#     → aborta el push con instrucciones.
#   - Bypass de emergencia: git push --no-verify.
#
# Instalado vía `core.hooksPath = brain/scripts/hooks` en bootstrap.sh §7 / npm run env:init.
#
# Nota de arquitectura: engram escribe a .engram/ (su convención interna); ese path
# es un symlink → .memory/ (el dir canónico versionado en git). ADR-0002 describe
# el modelo; este hook inspecciona .memory/ directamente para evitar ambigüedad.

# ── S4.8 note — reliability-first deviation from literal spec ──────────────
# Hard-blocking the PR-level invariants (issue-link, adr-presence,
# memory-presence) here would cause false-positives → developers use
# --no-verify, defeating governance.  Pre-push hard-blocks ONLY:
#   (a) uncommitted memory (existing)
#   (b) repo:check — reference/prohibition violations (new)
# Diff-size is a WARNING only (dev may be about to split PRs).
# brain:audit is where ALL 4 invariants are enforced hard (on merged history).
# ────────────────────────────────────────────────────────────────────────────

# Sin node no hay dispatcher — no bloquear (entorno mínimo).
command -v node >/dev/null 2>&1 || exit 0

# Locate repo root so the dispatcher path is absolute regardless of cwd.
repo_root=$(git rev-parse --show-toplevel)

# Materializar la memoria local en .memory/ vía dispatcher (backend-agnóstico).
# Si el export falla, no bloquear el push por un problema de tooling.
node "$repo_root/brain/scripts/memory/cli.mjs" share >/dev/null 2>&1 || exit 0

# Checkpoint the active feature's resume.md so the latest context travels
# with the branch on every push (REQ-S4-1).
# Non-blocking: || true ensures a failed or ambiguous-resolution checkpoint
# never aborts the push.
# Known limitation (A2): when multiple openspec/changes/ dirs exist the cli
# exits non-zero ("ambiguous"); || true swallows it and the push continues
# unaffected.  The committed resume.md remains the primary context-travel
# mechanism in that case.
node "$repo_root/brain/scripts/memory/cli.mjs" feature-checkpoint 2>/dev/null || true

# ── repo:check (hard — no false positives) ──────────────────────────────────
node "$repo_root/brain/scripts/check-refs.mjs" || exit 1

# ── diff-size WARNING (informational only — never blocks) ────────────────────
base=$(git merge-base HEAD origin/main 2>/dev/null) || base=""
if [ -n "$base" ]; then
  diff_lines=$(git diff --numstat "$base" HEAD \
    | node "$repo_root/brain/scripts/vcs/diff-size-count.mjs" 2>/dev/null) || diff_lines=""
  if [ -n "$diff_lines" ] && [ "$diff_lines" -gt 400 ] 2>/dev/null; then
    echo ""
    echo "⚠ pre-push: ~${diff_lines} changed lines (budget: 400)."
    echo "  Consider splitting before opening a review (this push continues)."
    echo ""
  fi
fi

# ── uncommitted .memory/ check (WARNING — reliability-first, never blocks) ────
# Rationale (ADR-0014 §9): `memory:share` above re-materializes the manifest,
# which is non-deterministic (it churns), so a hard block here would self-block
# the very push it runs on → developers reach for --no-verify, silencing the
# whole hook. `brain:save` is the proper materialize-and-commit point, and
# `brain:audit` enforces memory-presence on the merge to main. So: WARN here.
pending=$(git -C "$repo_root" status --porcelain -- .memory)

if [ -n "$pending" ]; then
  echo ""
  echo "⚠ pre-push: memoria viva sin commitear en .memory/ (este push continúa)."
  echo "  Materializá con 'brain:save' (o: git add .memory && git commit -m 'chore(memory): sync .memory')."
  echo "  El audit verifica memory-presence en el merge a main."
  echo ""
fi

exit 0
