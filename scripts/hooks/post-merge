#!/usr/bin/env sh
# post-merge — best-effort engram re-import after a pull/merge (issue #59 / ADR-0002).
#
# Triggered automatically by git after:
#   - git pull (when it results in a merge or fast-forward)
#   - git merge
#
# Purpose: re-import .memory/ into local engram after git has integrated new commits,
# so that memory chunks committed upstream are immediately available in local engram.
#
# Uses "import" (import-only, no git pull) because git itself already completed
# the merge/pull before this hook fires. Running another git pull here would be
# redundant (extra network call) and risks infinite recursion on some git versions.
#
# Behaviour:
#   - Non-blocking (|| true): a failed import NEVER aborts the merge/pull.
#   - No node required for the guard — we call node only when it is available.
#   - Mirrors the defensive style of the pre-push hook.
#
# Installed via `core.hooksPath = scripts/hooks` (bootstrap.sh §7 / npm run env:init).

# Without node there is nothing to do — do not block.
command -v node >/dev/null 2>&1 || exit 0

repo_root=$(git rev-parse --show-toplevel)

# Re-import .memory/ into local engram now that the working tree is up-to-date.
# Uses "import" verb (engram sync --import only — no redundant git pull).
# || true: a failed import is informational, not a merge blocker.
node "$repo_root/scripts/memory/cli.mjs" import >/dev/null 2>&1 || true

exit 0
