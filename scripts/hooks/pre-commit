#!/usr/bin/env sh
# pre-commit — block direct commits to main/master + run repo:check.
#
# Hard checks (locally unambiguous — no false positives):
#   1. Block direct commit to main or master (PRs only).
#   2. repo:check — validates references and prohibited patterns.
#
# No-node guard: exits 0 if node is not available.
# Installed via core.hooksPath = scripts/hooks.

command -v node >/dev/null 2>&1 || exit 0

# ── 1. Block direct commits to main/master ──────────────────────────────────
branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  echo ""
  echo "✗ pre-commit: direct commits to '$branch' are not allowed."
  echo "  Create a feature branch and submit a PR."
  echo "  (bypass: git commit --no-verify)"
  echo ""
  exit 1
fi

# ── 2. repo:check ──────────────────────────────────────────────────────────
repo_root=$(git rev-parse --show-toplevel)
node "$repo_root/scripts/check-refs.mjs"
exit $?
