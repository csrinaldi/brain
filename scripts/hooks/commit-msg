#!/usr/bin/env sh
# commit-msg — validate conventional commit format + ticket reference.
#
# Hard checks (blocks the commit — both locally unambiguous):
#   1. Conventional commit format: <type>[(<scope>)][!]: <description>
#   2. Ticket ref (#N) — skipped for Merge and Revert commits.
#
# No-node guard: exits 0 if node is not available (minimal env).
# Installed via core.hooksPath = scripts/hooks.

command -v node >/dev/null 2>&1 || exit 0

COMMIT_MSG_FILE="$1"
msg=$(cat "$COMMIT_MSG_FILE")

[ -z "$msg" ] && exit 0

# Merge / Revert commits are exempt from both checks.
case "$msg" in
  Merge\ *|Revert\ *) exit 0 ;;
esac

# ── 1. Conventional commit format ───────────────────────────────────────────
if ! echo "$msg" | grep -qE \
  '^(feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert)(\([^)]+\))?(!)?: .+'; then
  echo ""
  echo "✗ commit-msg: message must follow Conventional Commits."
  echo "  Format:  <type>[(<scope>)]: <description>"
  echo "  Types:   feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert"
  echo "  Example: feat(auth): add JWT validation (#42)"
  echo ""
  exit 1
fi

# ── 2. Ticket reference ──────────────────────────────────────────────────────
if ! echo "$msg" | grep -qE '#[0-9]+'; then
  echo ""
  echo "✗ commit-msg: message must reference a ticket (#N)."
  echo "  Example: feat(auth): add JWT validation (#42)"
  echo "           or add 'Closes #N' in the commit body."
  echo ""
  exit 1
fi

exit 0
